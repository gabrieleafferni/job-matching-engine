# Copia questo file in `.env` e inserisci le tue chiavi.
# Il file `.env` e' escluso da git tramite .gitignore: non verra' mai committato.
#
# Nessuna chiave e' obbligatoria: la pipeline attiva automaticamente
# solo le fonti per cui trova una credenziale valida.
# Arbeitnow funziona sempre, senza autenticazione.

# --- Adzuna (gratis, https://developer.adzuna.com) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Careerjet (gratis, https://www.careerjet.com/partners/api/) ---
CAREERJET_AFFID=

# --- Jooble (gratis, https://jooble.org/api/about) ---
JOOBLE_KEY=

# --- JSearch via RapidAPI (freemium, https://rapidapi.com) ---
RAPIDAPI_KEY=

# --- Anthropic, per il re-ranking LLM (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=
